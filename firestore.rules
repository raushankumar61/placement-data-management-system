rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'admin';
    }
    function isStudent() {
      return isAuthenticated() && request.auth.token.role == 'student';
    }
    function isRecruiter() {
      return isAuthenticated() && request.auth.token.role == 'recruiter';
    }
    function isFaculty() {
      return isAuthenticated() && request.auth.token.role == 'faculty';
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdminOrFaculty() {
      return isAdmin() || isFaculty();
    }
    function isAdminOrRecruiter() {
      return isAdmin() || isRecruiter();
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      // Only the user themselves or admin can update their own profile
      // Role field can only be changed by admin
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Students ──────────────────────────────────────────────────────────────
    match /students/{studentId} {
      // Students can only read their own full profile.
      // Recruiters and faculty can read but with limited fields (enforce in backend).
      allow read: if isAdminOrFaculty() || isRecruiter() || isOwner(studentId);
      allow create: if isAdmin() || isOwner(studentId);
      allow update: if isAdmin() || isFaculty() || isOwner(studentId);
      allow delete: if isAdmin();
    }

    // ── Jobs ──────────────────────────────────────────────────────────────────
    match /jobs/{jobId} {
      allow read: if isAuthenticated();
      allow create: if isAdminOrRecruiter();
      allow update: if isAdmin() || (isRecruiter() && resource.data.postedBy == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ── Applications ──────────────────────────────────────────────────────────
    match /applications/{appId} {
      allow read: if isAdmin() || isFaculty()
        || (isStudent() && resource.data.studentId == request.auth.uid)
        || (isRecruiter() && resource.data.recruiterId == request.auth.uid);
      allow create: if isStudent();
      allow update: if isAdmin() || isAdminOrRecruiter();
      allow delete: if isAdmin();
    }

    // ── Recruiters ────────────────────────────────────────────────────────────
    match /recruiters/{recruiterId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(recruiterId) || isAdmin();
      allow update: if isAdmin() || isOwner(recruiterId);
      allow delete: if isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAdmin() || isFaculty()
        || (isStudent() && (resource.data.targetRole == null || resource.data.targetRole == 'all' || resource.data.targetRole == 'student') && (resource.data.targetUid == null || resource.data.targetUid == request.auth.uid))
        || (isRecruiter() && (resource.data.targetRole == null || resource.data.targetRole == 'all' || resource.data.targetRole == 'recruiter') && (resource.data.targetUid == null || resource.data.targetUid == request.auth.uid));
      allow create: if isAdminOrFaculty();
      // Only allow updating the read list for notifications visible to the caller.
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
        && (
          isAdmin() || isFaculty()
          || (isStudent() && (resource.data.targetRole == null || resource.data.targetRole == 'all' || resource.data.targetRole == 'student') && (resource.data.targetUid == null || resource.data.targetUid == request.auth.uid))
          || (isRecruiter() && (resource.data.targetRole == null || resource.data.targetRole == 'all' || resource.data.targetRole == 'recruiter') && (resource.data.targetUid == null || resource.data.targetUid == request.auth.uid))
        );
      allow delete: if isAdmin();
    }

    // ── Interviews ────────────────────────────────────────────────────────────
    match /interviews/{interviewId} {
      allow read: if isAuthenticated();
      allow create: if isAdminOrRecruiter() || isFaculty();
      allow update: if isAdminOrRecruiter() || isFaculty()
        || (isStudent() && resource.data.studentId == request.auth.uid);
      allow delete: if isAdminOrRecruiter();
    }

    // ── Reports ───────────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdminOrFaculty();
      allow write: if isAdmin();
    }

    // ── Recommendations ───────────────────────────────────────────────────────
    match /recommendations/{recId} {
      allow read: if isAdminOrFaculty()
        || (isStudent() && resource.data.studentId == request.auth.uid);
      allow create: if isFaculty() || isAdmin();
      allow update: if isFaculty() || isAdmin();
      allow delete: if isFaculty() || isAdmin();
    }

    // ── System Activity (Audit Log) ───────────────────────────────────────────
    match /systemActivity/{activityId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated(); // backend writes via Admin SDK, bypasses rules
      allow update, delete: if false;     // immutable
    }

    // ── Complaints ────────────────────────────────────────────────────────────
    match /complaints/{complaintId} {
      allow read: if isAdmin() || isOwner(resource.data.createdBy);
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Shortlists ────────────────────────────────────────────────────────────
    match /shortlists/{shortlistId} {
      allow read: if isAdminOrRecruiter()
        || (isStudent() && resource.data.studentId == request.auth.uid);
      allow create: if isRecruiter() || isAdmin();
      allow update: if isAdminOrRecruiter();
      allow delete: if isAdminOrRecruiter();
    }

    // ── Verifications ─────────────────────────────────────────────────────────
    match /verifications/{verificationId} {
      allow read: if isAdminOrFaculty()
        || (isStudent() && resource.data.studentId == request.auth.uid);
      allow create: if isStudent() || isAdminOrFaculty();
      allow update: if isAdminOrFaculty();
      allow delete: if isAdmin();
    }

    // ── Mock Interviews ───────────────────────────────────────────────────────
    match /mockInterviews/{interviewId} {
      allow read: if isAdminOrFaculty()
        || (isStudent() && resource.data.studentId == request.auth.uid);
      allow create: if isStudent() || isAdminOrFaculty();
      allow update: if isAdminOrFaculty() || (isStudent() && resource.data.studentId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ── Placement Activities ──────────────────────────────────────────────────
    match /placementActivities/{activityId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdminOrFaculty();
      allow delete: if isAdmin();
    }

    // ── Notification Preferences ──────────────────────────────────────────────
    match /notificationPreferences/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }
  }
}
