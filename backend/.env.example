# Backend Environment Variables
# Copy this to .env and fill in your values
.
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Email (Nodemailer) — Optional, but needed for email notifications/reminders
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="PlaceCloud <no-reply@placecloud.app>"

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your_project_id
# Paste your service account JSON as a single-line string
# Supported variable names: FIREBASE_SERVICE_ACCOUNT_JSON or FIREBASE_SERVICE_ACCOUNT_KEY
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# CORS
FRONTEND_URL=http://localhost:3000

# Dev bypass (set to true to skip token verification in development)
BYPASS_AUTH=false

# Admin onboarding
# Required only if you want to allow admin signup from the Register page.
ADMIN_SETUP_KEY=change_me_admin_setup_key
