# Frontend Environment Variables
# Copy this to .env.local and fill in your Firebase project values

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Backend API URL
# Local dev can use /api/v1 via the Vite proxy.
# Production must point at the deployed backend base URL, for example:
# VITE_API_URL=https://your-backend.example.com/api/v1
VITE_API_URL=/api/v1
